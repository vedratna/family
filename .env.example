# ==========================================
# FamilyApp Environment Variables
# ==========================================
# Copy to .env.local and fill in values
# .env.local is gitignored — never commit secrets

# --- Local Development ---
MOCK_MODE=true                          # true = mock data, false = real API
API_URL=http://localhost:4000/graphql   # Local Express API or AppSync URL
STAGE=dev                               # dev | prod

# --- DynamoDB Local ---
DYNAMODB_ENDPOINT=http://localhost:8000  # Only for local development
TABLE_NAME=family-dev                    # DynamoDB table name

# --- AWS (for deployment) ---
AWS_REGION=ap-south-1
CDK_DEFAULT_ACCOUNT=                     # Your AWS account ID
CDK_DEFAULT_REGION=ap-south-1

# --- Auth Providers (stored in SSM, listed here for reference) ---
# GOOGLE_CLIENT_ID=                      # Google OAuth client ID
# APPLE_CLIENT_ID=                       # Apple Sign In service ID
# APPLE_TEAM_ID=                         # Apple Developer team ID
# APPLE_KEY_ID=                          # Apple Sign In key ID

# --- Expo EAS ---
# EXPO_TOKEN=                            # EAS build token (GitHub secret)
